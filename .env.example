# TitipDong environment — copy to .env and fill in real values.

# Your GitHub username or org (used to build the GHCR image tag).
GHCR_OWNER=titipdong

# 32+ character random string used to sign session cookies.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-bytes

# First-boot admin account (only created if no admin exists yet).
ADMIN_EMAIL=admin@titipdong.local
ADMIN_PASSWORD=change-this-strong-password

# Postgres password (the compose file uses it for both the DB and the app's DSN).
POSTGRES_PASSWORD=change-this-db-password

# Public base URL of your deployment (used for PWA manifest + absolute links).
BASE_URL=http://localhost:8080

# Optional: enable receipt/struk scan via OpenAI vision. Leave empty to hide the feature.
OPENAI_API_KEY=

# Optional: override the FX rate source (default is the free frankfurter.dev).
FX_BASE_URL=https://api.frankfurter.dev/v1
